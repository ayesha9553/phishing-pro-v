# PhishingPro Configuration — copy to .env and fill in values

# ── Threat Intelligence ──────────────────────────────────────────
# VirusTotal (optional) — free key at https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# PhishTank (optional) — free account at https://www.phishtank.com/register.php
PHISHTANK_APP_KEY=

# ── Generative AI ────────────────────────────────────────────────
# Choose provider: openai | gemini | none
AI_PROVIDER=none

# OpenAI API key — get at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini API key — get at https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# ── Email Gateway ────────────────────────────────────────────────
# Risk score thresholds for gateway action (0-100)
GATEWAY_QUARANTINE_THRESHOLD=60
GATEWAY_BLOCK_THRESHOLD=85

# IMAP Polling (optional — for polling a mailbox)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_FOLDER=INBOX
IMAP_POLL_INTERVAL=60

# ── Server ───────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=data/phishing.db

# ── Upload Limits ────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=25
